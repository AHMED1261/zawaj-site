# من Aiven -> Services -> اختار الداتابيز بتاعتك -> Overview -> Connection details
DB_HOST=your-service-name.aivencloud.com
DB_PORT=your-port-number
DB_USER=avnadmin
DB_PASSWORD=CHANGE_ME
DB_NAME=defaultdb
DB_SSL=true
PORT=3000

# سر توقيع الجلسات - غيّره لأي نص عشوائي طويل
JWT_SECRET=غيّر_ده_لنص_عشوائي_طويل_وسري

# حساب المشرف الافتراضي - بيتعمل أول تشغيل بس لو مش موجود
ADMIN_USERNAME=admin
ADMIN_PASSWORD=غيّر_الباسورد_ده_قبل_النشر
